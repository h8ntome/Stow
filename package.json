{
  "name": "stow",
  "version": "1.0.0",
  "description": "A smart local file organiser — sort files into folders using rules you define.",
  "type": "module",
  "bin": {
    "stow": "./bin/stow.js"
  },
  "main": "./src/core/config.js",
  "files": [
    "bin/",
    "src/",
    "public/"
  ],
  "scripts": {
    "start": "node bin/stow.js",
    "build:client": "vite build --config client/vite.config.js",
    "prepare": "npm run build:client",
    "dev:server": "node bin/stow.js",
    "dev:client": "vite --config client/vite.config.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "mime-types": "^2.1.35",
    "multer": "^1.4.5-lts.1",
    "open": "^10.0.3"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "lucide-react": "^0.344.0",
    "postcss": "^8.4.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^4.0.0",
    "vite": "^5.1.4"
  },
  "keywords": ["file", "organiser", "organizer", "cli", "sort", "files"],
  "license": "MIT"
}
